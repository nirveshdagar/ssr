# SSR Dashboard — Next.js port environment variables.
#
# Copy to `.env.local` for local dev, or set in your process manager / systemd
# unit for production. The Node side reads/writes the same SQLite database
# the Flask app uses; nothing here is secret-by-itself but the iron-session
# password and the Fernet key file together gate access to encrypted settings.

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# Iron-session cookie signing secret. MUST be at least 32 bytes. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# Rotating this invalidates every active session — operators have to log back in.
SSR_SESSION_PASSWORD=replace-with-a-base64-secret-of-at-least-32-bytes

# ---------------------------------------------------------------------------
# Optional — paths
# ---------------------------------------------------------------------------

# Absolute path to the shared SQLite DB. If unset, defaults to
#   <process.cwd()>/../data/ssr.db
# i.e. the same `data/ssr.db` the Flask app uses when run from the repo root.
# SSR_DB_PATH=C:/Users/operator/ssr-prod/data/ssr.db

# Absolute path to the Fernet key file used by lib/secrets-vault.ts. If unset,
# defaults to `<dirname(SSR_DB_PATH)>/.ssr_secret_fernet`. Auto-generated on
# first use with 0600 perms (best-effort on Windows).
# SSR_FERNET_KEY_PATH=C:/Users/operator/ssr-prod/data/.ssr_secret_fernet

# ---------------------------------------------------------------------------
# Optional — runtime tuning
# ---------------------------------------------------------------------------

# Number of in-process job workers (default 4; coerced to >=1).
# Set to 1 while Flask still owns job processing to mute Node side.
# SSR_JOB_WORKERS=4

# Live-checker is OFF by default in this Node port to avoid status thrash
# with a Flask live-checker running against the same DB. Set "1" to enable
# on Node — and stop the Flask one.
# SSR_LIVE_CHECKER=0

# Auto-launched on boot via instrumentation.ts:
#   - grey-cloud recovery (5s after start)
#   - orphan-droplet sweep (8s after start)
# Skipped automatically when NODE_ENV=test.
