# Secrets + state — NEVER commit
data/
.ssr_secret_fernet
.env
.env.local
.env.production
!.env.example
*.key
*.pem

# Python bytecode / venv
__pycache__/
*.py[cod]
*$py.class
*.so
venv/
.venv/

# Editor / OS
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Logs / debug artifacts
# NOTE: keep `/logs/` anchored to repo root — an unanchored `logs/` also
# matched the Next.js route dirs template_v0/app/logs/ and app/api/logs/,
# silently keeping them out of git (caused a prod 404 on /logs).
*.log
/logs/

# Node — only template_v0/ has a package.json, but stray probe scripts run
# from the root sometimes pull deps into a root-level node_modules
node_modules/

# Build / distribution
DEPLOY.zip
dist/
build/
*.egg-info/

# Stray SQLite DBs (real DB lives at data/ssr.db; empty *.sqlite3 files
# appear when SSR_DB_PATH is unset and a probe script falls back to cwd)
*.sqlite3

# TypeScript incremental compile cache — auto-regenerated, shouldn't be tracked
tsconfig.tsbuildinfo

# Next.js regenerates this on EVERY `next build`/`next dev`. It was committed
# by mistake, so each prod build dirtied it and made the next `git pull`
# abort ("local changes would be overwritten") — silently freezing the DO
# droplet on stale code for days. Auto-generated; must never be tracked.
/template_v0/next-env.d.ts

# One-off debug / probe scripts left by AI sessions (tmp_*.mjs, tmp_*.sh, etc.).
# These accidentally got committed once — keep them out of git permanently.
tmp_*.mjs
tmp_*.sh
tmp_*.js

# Claude Code per-conversation scheduled-task state (transient session data)
.claude/scheduled_tasks.lock

# Session notes with secrets — local-only
PROGRESS.md

# Claude Code per-user permission allowlist — may contain secrets in command args
.claude/settings.local.json
